{
  "version": 2,
  "buildCommand": "npm run deploy",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "outputDirectory": "artifacts/api-server/client",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
