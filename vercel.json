{
  "version": 2,
  "buildCommand": "pnpm run build:netlify",
  "installCommand": "pnpm install",
  "devCommand": "pnpm run dev",
  "outputDirectory": "artifacts/api-server/client",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
